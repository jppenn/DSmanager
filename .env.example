# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Publishable key (safe for the browser). Found under Project Settings > API Keys.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key
# Secret key (NEVER expose to the client). Used for cron + privileged writes.
SUPABASE_SECRET_KEY=sb_secret_your-key

# Resend
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL="Dropship Manager <orders@yourdomain.com>"

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron protection (Vercel sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=generate-a-long-random-string
